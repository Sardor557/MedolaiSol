{
  "ConnectionStrings": {
    "DbConnectionString": "Host=localhost;Database=medolai_db;Username=postgres;Password=postgres;Pooling=true;KeepAlive=240",
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Telegram", "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log.txt",
          "flushToDiskInterval": 1,
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "OpenTelemetry": {
    "AspNetCoreInstrumentation": 1,
    "HttpClientInstrumentation": 1,
    "RuntimeInstrumentation": 1,
    "ProcessInstrumentation": 1
  },


  "AllowedHosts": "*",

  "JWT": {
    "ValidAudience": "https://sardor.uz",
    "ValidIssuer": "https://sardor.uz",
    "Secret": "ayhsasd-7DD8-4F43-24C5-asgtwqad  from this section alo",
    "TokenValidityInHours": 11,
    "RefreshTokenValidityInHours": 24
  },

  "Vars": {
    "CacheTimeOut": 5,
    "ServerUrl": "https://localhost:7897"
  }
}
